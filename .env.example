# Postgres (used by docker-compose and the backend)
POSTGRES_USER=coverage_copilot
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=coverage_copilot
POSTGRES_PORT=5432
# Used when running the backend outside Docker; docker-compose overrides this
# to point at the "postgres" service hostname for containers.
DATABASE_URL=postgresql://coverage_copilot:change-me-locally@localhost:5432/coverage_copilot

# Backend
BACKEND_PORT=4000
CORS_ORIGIN=http://localhost:5173

# LLM + embeddings (server-side only, per CLAUDE.md Security 4.1).
# OpenAI is the single provider: text-embedding-3-small for ingestion (M2) and
# gpt-4o for coverage-answer generation (M3, via the Vercel AI SDK).
OPENAI_API_KEY=sk-placeholder

# Optional/unused: build-spec §8 targeted Claude for generation. Set this only
# if you switch the generation provider back to Anthropic.
# ANTHROPIC_API_KEY=sk-ant-placeholder

# Frontend (build-time; safe to expose, points at the backend only)
VITE_GRAPHQL_URL=http://localhost:4000/graphql
